MODULE TRANSACTIONS
POST /api/wallets/{id}/deposit  —  Déposer de l’argent
Body de la requête :
{
"amount": 500.00,
"description": "Dépôt initial"
}

Status: 200 OK
{
"success": true,
"message": "Dépôt effectué avec succès.",
"data": {
"transaction": {
"id": 1,
"wallet_id": 1,
"type": "deposit",
"amount": "500.00",
"description": "Dépôt initial",
"balance_after": "2000.00",
"created_at": "2026-03-10T11:00:00.000000Z"
},
"wallet": {
"id": 1,
"name": "Wallet Principal",
"currency": "MAD",
"balance": "2000.00"
}
}
}

Status: 422 Unprocessable Entity
{
"success": false,
"message": "Erreur de validation.",
"errors": {
"amount": ["Le montant doit être supérieur à 0."]
}
}

POST /api/wallets/{id}/withdraw  —  Retirer de l’argent
Body de la requête :
{
"amount": 200.00,
"description": "Retrait DAB"
}

Status: 200 OK
{
"success": true,
"message": "Retrait effectué avec succès.",
"data": {
"transaction": {
"id": 2,
"wallet_id": 1,
"type": "withdraw",
"amount": "200.00",
"description": "Retrait DAB",
"balance_after": "1800.00",

},
"wallet": {
"id": 1,
"name": "Wallet Principal",
"currency": "MAD",
"balance": "1800.00"
}
}
}

Status: 400 Bad Request
{
"success": false,
"message": "Solde insuffisant. Solde actuel : 100.00 MAD."
}


POST /api/wallets/{id}/transfer  —  Transférer vers un autre wallet
Body de la requête :
{
"receiver_wallet_id": 3,
"amount": 100.00,
"description": "Remboursement déjeuner"
}

Status: 200 OK
{
"success": true,
"message": "Transfert effectué avec succès.",
"data": {
"transaction_out": {
"id": 3,
"wallet_id": 1,
"type": "transfer_out",
"amount": "100.00",
"description": "Remboursement déjeuner",
"receiver_wallet_id": 3,
"balance_after": "1700.00",
"created_at": "2026-03-10T12:00:00.000000Z"
},
"transaction_in": {
"id": 4,
"wallet_id": 3,
"type": "transfer_in",
"amount": "100.00",
"description": "Remboursement déjeuner",
"sender_wallet_id": 1,
"balance_after": "350.00",
"created_at": "2026-03-10T12:00:00.000000Z"
},
"wallet": {
"id": 1,
"name": "Wallet Principal",
"currency": "MAD",
"balance": "1700.00"
}
}
}

Status: 400 Bad Request – Solde insuffisant
{
"success": false,
"message": "Solde insuffisant. Solde actuel : 50.00 MAD."
}

Status: 400 Bad Request – Devise incompatible
{
"success": false,
"message": "Transfert impossible : les deux wallets doivent avoir la même devise."
}

Status: 422 Unprocessable Entity
{
"success": false,
"message": "Erreur de validation.",
"errors": {
"receiver_wallet_id": ["Le wallet destinataire est obligatoire."],
"amount": ["Le montant doit être supérieur à 0."]
